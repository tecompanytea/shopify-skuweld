# Shopify (from Partner Dashboard after `shopify app config link`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://skuweld.vercel.app
SCOPES=read_inventory,read_locations,read_products

# Postgres (Neon: pooled for runtime, unpooled for migrations)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Square (Production credentials from developer.squareup.com)
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_REDIRECT_URL=https://skuweld.vercel.app/square/auth/callback

# Generate with: openssl rand -hex 32
SQUARE_STATE_SECRET=
SQUARE_TOKEN_ENCRYPTION_KEY=

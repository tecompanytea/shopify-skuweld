// Source-of-truth note:
// Shopify owns Product, ProductVariant, Inventory. Square owns CatalogItem,
// CatalogItemVariation, InventoryCount. This DB stores the Shopify session,
// the Square OAuth connection, and the SKU master list + naming rules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// One Square account linked per shop. v1 stores mainLocationId only;
// a SquareLocation model is added later for per-location inventory/analytics.
model SquareConnection {
  id             String   @id @default(cuid())
  shop           String   @unique
  merchantId     String
  merchantName   String?
  mainLocationId String?
  accessToken    String // AES-256-GCM, base64(iv.tag.ciphertext)
  refreshToken   String // encrypted the same way
  expiresAt      DateTime // access token expiry (~30 days, refreshed on use)
  scopes         String // granted scopes, space-separated
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Master SKU list: union of all normalized SKUs ever seen on either channel.
// Populated/refreshed only by the explicit "Sync SKUs" action; rows are kept
// (with presence flags flipped off) when a SKU disappears from a channel.
model Sku {
  id                String   @id @default(cuid())
  shop              String
  value             String // normalized: trim + uppercase
  rawValue          String // as last seen, for display
  productName       String? // last-seen product title (either channel)
  presentInShopify  Boolean  @default(false)
  presentInSquare   Boolean  @default(false)
  shopifyVariantGid String? // gid://shopify/ProductVariant/...
  squareVariationId String? // CatalogItemVariation id
  isClean           Boolean  @default(false) // cached rule evaluation
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shop, value])
  @@index([shop, isClean])
  @@index([shop, presentInShopify, presentInSquare])
}

// Analytics fact table: one row per order line (sale or return) from either
// channel, normalized. All report types aggregate this table. Money is in
// cents; sale rows are positive, return rows negative, so SUM() is correct.
// `day` is precomputed in America/New_York — the reports' bucketing rule.
model SalesLine {
  id            String   @id // source-prefixed natural key, e.g. "sq:<order>:<uid>"
  shop          String
  source        String // shopify | square
  channel       String // WV | EV | ECOM | INVOICED
  kind          String // sale | return
  orderId       String
  occurredAt    DateTime
  day           String // YYYY-MM-DD, America/New_York
  sku           String?
  itemName      String // as sold: the order line's snapshot name, kept for audit
  variationName String?
  // Stable product identity from the *current* catalog, unlike itemName:
  // "sq:<catalog item id>" / "sh:<product gid>". A Square item's variations
  // (the sizes) share one productKey, so grouping by it separates products
  // without splitting sizes. Null for custom/uncatalogued lines.
  productKey    String?
  productTitle  String? // current catalog name for productKey
  category      String? // Square category name / Shopify product type
  quantity      Float // signed; Square quantities can be fractional
  grossCents    Int // signed
  discountCents Int // signed; amount subtracted from gross
  netCents      Int // signed; gross - discount
  taxCents      Int // signed
  syncedAt      DateTime @updatedAt

  @@index([shop, day])
  @@index([shop, channel, day])
  @@index([shop, category, day])
  @@index([shop, productKey])
}

// Progress per sync job (id = `${shop}:${key}`), so long backfills are
// resumable and the UI can show what happened.
model SyncState {
  id        String    @id
  shop      String
  status    String    @default("idle") // idle | running | done | error
  progress  String?
  error     String?
  // High-water mark for the incremental sync: the instant the last *successful*
  // pull completed. Set only on success (so a failure can't advance it), and
  // advanced even on a no-op refresh that found zero changed orders — which is
  // why freshness and resolveIncrementalSince both read it instead of
  // max(SalesLine.syncedAt) (that only moves when rows are actually written).
  watermark DateTime?
  updatedAt DateTime  @updatedAt
}

// Configurable SKU naming rules; a SKU is "clean" iff every enabled rule passes.
model SkuRule {
  id        String   @id @default(cuid())
  shop      String
  name      String // human label, e.g. "Tea SKUs start with TE-"
  type      String // REGEX | PREFIX | MIN_LENGTH | MAX_LENGTH | NO_SPACES | DIGITS_ONLY | UPPERCASE
  value     String? // pattern / prefix / length; null for boolean checks
  enabled   Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}
